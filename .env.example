# Snaplook Environment Variables Configuration
# SECURITY: This is an example file. NEVER commit actual credentials to version control.
#
# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace all placeholder values with your actual credentials
# 3. Ensure .env is listed in .gitignore (it should be by default)
# 4. Run the app with: flutter run --dart-define-from-file=.env

# === Supabase Configuration (REQUIRED) ===
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# === SerpAPI Configuration (REQUIRED) ===
# Product search API key
# Get from: https://serpapi.com/manage-api-key
SERPAPI_API_KEY=your-serpapi-key-here

# === ScrapingBee Configuration (REQUIRED) ===
# Web scraping API for Instagram/social media downloads
# Get from: https://app.scrapingbee.com/account/api-keys
SCRAPINGBEE_API_KEY=your-scrapingbee-key-here

# === Superwall Configuration (REQUIRED) ===
# Subscription paywall service
# Get from: https://superwall.com/dashboard
SUPERWALL_API_KEY=your-superwall-api-key-here

# === Detection API Endpoints (REQUIRED FOR PRODUCTION) ===
# Your backend endpoints for fashion detection
DETECT_ENDPOINT=https://your-backend.com/detect
DETECT_AND_SEARCH_ENDPOINT=https://your-backend.com/detect-and-search

# === Cloudinary Configuration (OPTIONAL) ===
# Image hosting and processing service
# Get from: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# === Stock Photo APIs (OPTIONAL) ===
# For placeholder images and inspiration
PEXELS_API_KEY=your-pexels-api-key
PIXABAY_API_KEY=your-pixabay-api-key
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# === Search Configuration (OPTIONAL) ===
# Geographic location for search results (e.g., "United States", "New York, NY")
SEARCHAPI_LOCATION=United States

# === Development Settings (OPTIONAL) ===
# Set to true to use local API server instead of production endpoints
# USE_LOCAL_API=false

# ==========================================
# SECURITY BEST PRACTICES
# ==========================================
#
# 1. NEVER commit .env file to git
# 2. NEVER share API keys in Slack, email, or documentation
# 3. ROTATE keys immediately if accidentally exposed
# 4. Use different keys for development and production
# 5. Set up key rotation schedule (every 90 days recommended)
# 6. Monitor API usage for anomalies
# 7. Use environment-specific .env files (.env.dev, .env.prod)
# 8. In CI/CD, use secret management (GitHub Secrets, AWS Secrets Manager)
#
# Key Rotation Guide:
# - Supabase: Project Settings > API > Reset JWT Secret
# - SerpAPI: Account > API Key > Regenerate
# - ScrapingBee: API Keys > Create New Key
# - Superwall: Dashboard > Settings > API Keys > Rotate
#
# If keys are compromised:
# 1. Rotate ALL keys immediately
# 2. Review API usage logs for unauthorized access
# 3. Check billing for unexpected charges
# 4. Update .env files on all development machines
# 5. Update CI/CD secrets
# 6. Deploy new build with updated keys
